{
  "mcpServers": {
    "image-redaction-service": {
      "command": "node",
      "args": [
        "/absolute/path/to/image-redaction-service/src/mcp/stdio.js"
      ],
      "env": {
        "MAX_IMAGE_BYTES": "10485760",
        "MAX_REGIONS": "100",
        "ALLOW_REMOTE_IMAGE_SOURCE": "false"
      }
    }
  }
}
