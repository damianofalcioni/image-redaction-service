{
  "mcpServers": {
    "image-redaction-service": {
      "command": "node",
      "args": [
        "/absolute/path/to/image-redaction-service/src/mcp/stdio.js"
      ],
      "env": {
        "MAX_IMAGE_BYTES": "10485760",
        "MAX_REGIONS": "100",
        "MAX_BATCH_IMAGES": "10",
        "BATCH_CONCURRENCY": "4",
        "MAX_PDF_BYTES": "26214400",
        "MAX_PDF_PAGES": "100",
        "ALLOW_REMOTE_IMAGE_SOURCE": "false",
        "ALLOW_REMOTE_PDF_SOURCE": "false"
      }
    }
  }
}
