{
  "name": "image-redaction-service",
  "version": "0.4.0",
  "description": "REST and MCP service for redacting sensitive image regions, batch image redaction, and PDF-to-JPEG conversion.",
  "type": "module",
  "main": "src/index.js",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "start": "node --env-file=.env src/index.js",
    "dev": "node --env-file=.env --watch src/index.js",
    "mcp:stdio": "node --env-file=.env src/mcp/stdio.js",
    "test": "node --test",
    "lint": "eslint .",
    "check": "npm run lint && find src test test-support -name \"*.js\" -print0 | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.2.1",
    "sharp": "^0.33.5",
    "zod": "^4.4.3",
    "@napi-rs/canvas": "^1.0.2",
    "pdfjs-dist": "4.10.38"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^15.14.0",
    "ts-api-utils": "2.5.0",
    "typescript": "5.9.3"
  }
}
